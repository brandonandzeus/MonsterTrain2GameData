  "battleNameKey": {
    "key": "ScenarioData_battleNameKey-6028328cda1c4f70-cebdaee0c70c76a4c9a7686c3241485b-v2",
    "english": "Thaddeus the Indulgent",
    "french": "Thaddeus l'Indulgent",
    "german": "Thaddeus der Duldsame",
    "russian": "Тадеус Ненасытный",
    "portuguese": "Thaddeaus, o Indulgente",
    "chinese": "放纵者萨铎斯",
    "spanish": "Thaddeus el Indulgente",
    "chinese_traditional": "放縱的薩迪厄斯",
    "korean": "탐닉자 타디우스",
    "japanese": "寛大なるタデウス"
  },
  "battleDescriptionKey": {
    "key": "ScenarioData_battleDescriptionKey-0bf74558ec2f193b-cebdaee0c70c76a4c9a7686c3241485b-v2",
    "english": "The gruesome hunger of Thaddeus is neverending. With each foe he destroys, he gorges on his nearest meal with voracious excitement.",
    "french": "La soif de sang de Thaddeus est insatiable. Chaque adversaire qu'il abat devient un festin qu'il dévore avec une fureur monstrueuse.",
    "german": "Der schauerliche Hunger von Thaddäus scheint unendlich. Nach jedem vernichteten Widersacher stürzt er sich mit gieriger Raserei auf sein nächstes Mahl.",
    "russian": "Жуткий голод Тадеуса неутолим. После каждого убийства он с жадностью набрасывается на ближайшую закуску.",
    "portuguese": "A fome horrível de Thaddeaus é infinita. A cada inimigo que ele destrói, ele devora sua refeição mais próxima com entusiasmo voraz.",
    "chinese": "萨铎斯的饥饿永远无法满足，令人胆寒。他每消灭一个敌人，就会兴奋地对着离他最近的餐食大快朵颐。",
    "spanish": "El hambre salvaje de Thaddeus es insaciable. Con cada enemigo que destruye, se abalanza sobre el alimento más cercano con un entusiasmo voraz.",
    "chinese_traditional": "薩迪厄斯的恐怖飢餓永無止盡。每消滅一個敵人，他便會興奮且貪婪地吞噬眼前最近的獵物。",
    "korean": "타디우스의 잔인한 굶주림은 영원히 계속됩니다. 그는 적을 제거할 때마다, 가장 가까운 식량을 향해 맹렬한 욕망을 드러내며 탐식합니다.",
    "japanese": "タデウスの身の毛のよだつような飢えは決して満たされない。討ち滅ぼした敵は、次の食事の際にガツガツと貪り食う。"
  },
