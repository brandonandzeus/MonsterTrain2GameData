  "battleNameKey": {
    "key": "ScenarioData_battleNameKey-4fe5248d4958cf4a-e4c3719c3336edb4f818eccd05cbbe34-v2",
    "english": "Rabble-Rousers",
    "french": "Trublions",
    "german": "Aufwiegler",
    "russian": "Смутьяны",
    "portuguese": "Agitadores",
    "chinese": "暴民煽动者",
    "spanish": "Agitadores",
    "chinese_traditional": "煽動者",
    "korean": "선동꾼",
    "japanese": "ラブル・ラウザー"
  },
  "battleDescriptionKey": {
    "key": "ScenarioData_battleDescriptionKey-b3f07a7f01f62b33-e4c3719c3336edb4f818eccd05cbbe34-v2",
    "english": "Cruel laughter reverberates along the train. These enemies seek to taunt and disrupt as much as they wish to destroy.",
    "french": "Des ricanements sadiques résonnent à travers le train. Ces adversaires ne cherchent pas seulement à vous détruire, mais aussi à vous narguer et à briser vos rangs.",
    "german": "Grausames Gelächter erklingt durch den Zug. Diese Feinde wollen nicht nur zerstören, sondern ebenso bereitwillig verspotten und stören.",
    "russian": "Жестокий смех катится вдоль состава: эти твари живут, чтобы дразнить, сбивать строй и ломать все, до чего дотянутся.",
    "portuguese": "Risos cruéis ecoam ao longo do trem. Estes inimigos procuram provocar e perturbar tanto quanto desejam destruir.",
    "chinese": "无情的笑声在车厢里回荡。这些敌人既想消灭你，又想嘲讽你以及制造混乱。",
    "spanish": "Unas risas crueles resuenan por el tren. Estos enemigos quieren provocar e interferir tanto como quieren destruir.",
    "chinese_traditional": "殘酷的笑聲在列車間迴盪。這些敵人渴望破壞，更樂於進行嘲弄與擾亂。",
    "korean": "잔혹한 웃음소리가 열차 안에 울려 퍼집니다. 이 적들은 적을 파괴하는 동시에, 도발하고 혼란을 일으키려 합니다.",
    "japanese": "列車の中を残酷な笑いが響き渡る。この敵は破壊だけでなく、挑発や妨害も同じくらい好む。"
  },
