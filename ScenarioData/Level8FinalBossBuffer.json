  "battleNameKey": {
    "key": "ScenarioData_battleNameKey-fb5447904a9a442e-e26399265883a4049aa09b75ffa8a105-v2",
    "english": "Seraph Aeternus, Chosen of Entropy",
    "french": "Séraphin Aeternus, Élu d'Entropie",
    "german": "Seraph Aeternus, Entropies Erwählter",
    "russian": "Серафим Бессмертный — Избранник Энтропии",
    "portuguese": "Serafim Aeternus, o Escolhido da Entropia",
    "chinese": "永恒炽天使，混乱泰坦的神选者",
    "spanish": "Seraph Aeternus, elegido de Entropía",
    "chinese_traditional": "『熵之天選』撒拉弗‧艾特努斯",
    "korean": "엔트로피의 선택을 받은 자, 세라핌 아이테르누스",
    "japanese": "セラフ・エーテルヌス、エントロピーに選ばれし者"
  },
  "battleDescriptionKey": {
    "key": "ScenarioData_battleDescriptionKey-edbaa29a03cbe5a4-e26399265883a4049aa09b75ffa8a105-v2",
    "english": "Unrecognizable from his original form, Seraph has returned as a puppet of Titans from the abyss. Seraph's Entropic form will <b>sap your units’ strength</b>.",
    "french": "Méconnaissable sous son aspect actuel, Séraphin est revenu de l'abîme réduit à l'état de marionnette des titans. Sa forme entropique <b>sape la défense de vos unités</b>.",
    "german": "Seraph kehrte bis zur Unkenntlichkeit verändert als Marionette der Titanen aus dem Abgrund zurück. Seine entropische Form wird <b>an der Stärke deiner Einheiten zehren</b>.",
    "russian": "Серафим вернулся из Бездны, став марионеткой титанов — теперь его сложно узнать. В обличии, данном ему Энтропией, Серафим будет <b>высасывать силы из ваших союзников</b>.",
    "portuguese": "Agora irreconhecível, Serafim retornou do abismo como um fantoche dos Titãs. A forma da Entropia do Serafim <b>drenará a força de suas unidades</b>.",
    "chinese": "面目全非的炽天使已作为泰坦的傀儡从深渊中归来。炽天使的混乱泰坦形态会<b>弱化你单位的力量</b>。",
    "spanish": "Seraph, irreconocible de su forma original, ha regresado del abismo como títere de los titanes. La forma Entrópica de Seraph <b>marchitará la fuerza de tus unidades</b>.",
    "chinese_traditional": "撒拉弗原本的形態難以辨認，這次變成深淵泰坦的傀儡歸來。撒拉弗的熵之形態將<b>吸取你單位的力量</b>。",
    "korean": "원래 모습마저 잃어버린 채, 세라핌이 티탄의 꼭두각시가 되어 심연 너머에서 돌아왔습니다. 엔트로피의 힘을 얻은 세라핌은 아군 유닛의 <b>힘을 서서히 앗아갑니다</b>.",
    "japanese": "以前の姿は見る影もなくなってしまったセラフは、深淵から来た巨人族の操り人形となって戻ってきた。セラフのエントロピー形態は<b>自軍のユニットの強さを奪う</b>。"
  },
