  "battleNameKey": {
    "key": "ScenarioData_battleNameKey-6ed742bd211e57f8-769a1ee582035a24ba0d8fbb6d70782d-v2",
    "english": "The Lifemother",
    "french": "Mère Nature",
    "german": "Die Lebensmutter",
    "russian": "Мать-природа",
    "portuguese": "A Genetriz",
    "chinese": "生命之母",
    "spanish": "La Madre Vida",
    "chinese_traditional": "生命之母",
    "korean": "생명의 어머니",
    "japanese": "ライフマザー"
  },
  "battleDescriptionKey": {
    "key": "ScenarioData_battleDescriptionKey-4a613277d78283c8-769a1ee582035a24ba0d8fbb6d70782d-v2",
    "english": "Eons of being trapped in the Soulstream has driven the Lifemother to madness. The Lifemother will use her powers to <b>weaken</b> the lifeforce of your army.",
    "french": "Prisonnière du Flux des âmes pendant des millénaires, Mère Nature a fini par perdre la raison. Elle utilisera ses pouvoirs pour <b>affaiblir</b> vos troupes.",
    "german": "Äonen der Gefangenschaft im Seelenstrom ließen die Lebensmutter wahnsinnig werden. Sie wird ihre Kräfte dazu einsetzen, die Kampfkraft deiner Armee zu <b>schwächen</b>.",
    "russian": "Бесчисленные годы вынужденного пребывания в Ручье Душ свели Мать-природу с ума. Она будет <b>высасывать</b> из ваших бойцов жизненные силы.",
    "portuguese": "Eras presa no Fluxo de Almas levaram a Genetriz à loucura. A Genetriz usará seus poderes para <b>enfraquecer</b> a força vital do seu exército.",
    "chinese": "生命之母因被困在灵魂之流无数年而陷入疯狂。生命之母会用自己的力量<b>削弱</b>你军队的生命力。",
    "spanish": "Los eones de encierro en la Corriente de Almas han hecho enloquecer a la Madre Vida. Utilizará sus poderes para <b>debilitar</b> la fuerza vital de tu ejército.",
    "chinese_traditional": "囚禁於靈魂之流的漫長歲月，已將生命之母逼入瘋狂。她將運用力量<b>削弱</b>你軍隊的生命力。",
    "korean": "영겁의 세월 동안 소울스트림에 갇혀 있던 생명의 어머니는 광기에 사로잡혔습니다. 생명의 어머니는 자신의 힘을 사용해 당신의 군대의 생명력을 <b>약화</b>시킬 것입니다.",
    "japanese": "悠久とも思える時をソウルストリームに囚われ過ごし、ライフマザーは狂気に陥ったしまった。ライフマザーは、敵の生命力を<b>弱体化</b>するために力を使う。"
  },
