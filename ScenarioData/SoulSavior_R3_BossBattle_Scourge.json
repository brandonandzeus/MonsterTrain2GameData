  "battleNameKey": {
    "key": "ScenarioData_battleNameKey-b356c14d99feb083-ff287e67e7bb38642968f1ea3ef09c94-v2",
    "english": "Tivi the Unruly",
    "french": "Tivi l'Indocile",
    "german": "Tivi der Ungezogene",
    "russian": "Тиви Непокорный",
    "portuguese": "Tivi, o Baderneiro",
    "chinese": "任性者蒂维",
    "spanish": "Tivi el Inquieto",
    "chinese_traditional": "不羈的蒂維",
    "korean": "무법자 티비",
    "japanese": "悪童のティヴィー"
  },
  "battleDescriptionKey": {
    "key": "ScenarioData_battleDescriptionKey-5675d84c8cac69a0-ff287e67e7bb38642968f1ea3ef09c94-v2",
    "english": "Tivi never fights fair. Beware of Tivi's scourges, while they may seem innocuous, they will quickly leave your hands full.",
    "french": "Tivi ne se bat jamais à la loyale. Méfiez-vous de ses <nobr>Plaies :</nobr> sous leur apparence anodine, elles auront tôt fait de vous submerger.",
    "german": "Tivi kämpft niemals mit fairen Mitteln. Hüte dich vor Tivis Schergen! Sie scheinen harmlos, doch du wirst mit ihnen alle Hände voll zu tun haben.",
    "russian": "Тиви не знает, что такое честный бой. Его плети выглядят игрушечными, но стоит моргнуть — и уже отбиваешься от них изо всех сил.",
    "portuguese": "Tivi nunca luta de forma justa. Cuidado com os flagelos de Tivi, pois embora possam parecer inofensivos, eles rapidamente deixarão suas mãos ocupadas.",
    "chinese": "蒂维从来都不讲武德。当心蒂维的天灾，它们虽然看起来完全无害，但很快就会占满你的手牌。",
    "spanish": "Tivi nunca juega limpio. Cuidado con los azotes de Tivi: parecen inocuos, pero pronto te llenarán la mano.",
    "chinese_traditional": "蒂維從不正大光明地戰鬥。當心他的「禍害」，雖然看似無害，卻能迅速塞滿你的手牌。",
    "korean": "티비는 항상 비열한 방식으로 싸웁니다. 겉보기에는 무해해 보일지라도, 티비의 재앙들을 경계하십시오. 순식간에 감당하기 벅찬 상황에 몰리게 될 것입니다.",
    "japanese": "ティヴィーは決して公平に戦わない。ティヴィーの災難には注意が必要だ。無害のように思えて、あっという間に厄介なものになる。"
  },
