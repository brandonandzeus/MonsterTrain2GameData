  "battleNameKey": {
    "key": "ScenarioData_battleNameKey-84be4d4f3173f3ae-bc7b4ce5babc9904095a7b8e5a70099f-v2",
    "english": "Purified Hordes",
    "french": "Hordes purifiées",
    "german": "Geläuterte Horden",
    "russian": "Орды очищенных",
    "portuguese": "Hordas Purificadas",
    "chinese": "净化大军",
    "spanish": "Hordas purificadas",
    "chinese_traditional": "淨化軍團",
    "korean": "정화된 무리",
    "japanese": "浄化の大群"
  },
  "battleDescriptionKey": {
    "key": "ScenarioData_battleDescriptionKey-cd40d4d4a0566e0f-bc7b4ce5babc9904095a7b8e5a70099f-v2",
    "english": "These high angels are Pure Souls no longer, instead they've succumbed to the Titans' corruption. Purify them before they reach the Pyre.",
    "french": "Ces anges autrefois majestueux ne sont plus des âmes pures, car ils ont succombé à la corruption des titans. Éradiquez-les avant qu'ils n'atteignent le Brasier.",
    "german": "Diese hohen Engel haben keine reinen Seelen mehr, sondern sind der Verderbnis der Titanen erlegen. Läutere sie, bevor sie die Höllenglut erreichen.",
    "russian": "Чистые души этих высших ангелов давно осквернены титанами. Смойте эту скверну кровью прежде, чем они доберутся до Пекла.",
    "portuguese": "Esses anjos elevados não são mais Almas Puras, mas sucumbiram à corrupção dos Titãs. Purifique-os antes que cheguem à Pira.",
    "chinese": "这些天使已不再拥有纯洁的灵魂，与此相反，他们已屈服于泰坦的腐化。净化他们，别让他们靠近薪火。",
    "spanish": "Estos ángeles superiores ya non son almas puras, pues han sucumbido a la corrupción de los titanes. Purifícalos antes de que lleguen a la Pira.",
    "chinese_traditional": "這些高階天使不再是純潔的靈魂，相反，他們已屈服於泰坦的腐化。在他們到達火堆之前淨化他們。",
    "korean": "티탄의 타락에 굴복하여 순수한 영혼을 더는 지니지 않은 대천사입니다. 화로에 도달하기 전에 정화하세요.",
    "japanese": "この高位の天使たちはもはや純粋な魂ではなく、巨人族の堕落に屈している。炉に到達する前に浄化せよ。"
  },
