  "battleNameKey": {
    "key": "ScenarioData_battleNameKey-f809cd68e168b3ff-4b2078873e49b244bbe623d89dd8ae1f-v2",
    "english": "Gluttonous Masses",
    "french": "Masses voraces",
    "german": "Gefräßige Massen",
    "russian": "Прожорливые массы",
    "portuguese": "Massas Glutonas",
    "chinese": "暴食团块",
    "spanish": "Masas insaciables",
    "chinese_traditional": "暴食巨塊",
    "korean": "탐식의 무리",
    "japanese": "貪欲の集合体"
  },
  "battleDescriptionKey": {
    "key": "ScenarioData_battleDescriptionKey-4bc3f75be331943f-4b2078873e49b244bbe623d89dd8ae1f-v2",
    "english": "Be wary of those that come from the Soulstream. For they will do anything to survive, even if it means feeding on their own kin.",
    "french": "Méfiez-vous des êtres issus du Flux des âmes. Ils sont prêts à tout pour survivre, y compris à dévorer leurs semblables.",
    "german": "Achte dich vor jenen, die aus dem Seelenstrom kommen. Sie werden alles tun, um zu überleben – selbst, wenn es bedeuten sollte, ihresgleichen zu verschlingen.",
    "russian": "Остерегайтесь тех, кто приходит из Ручья Душ: ради выживания они пойдут на все, даже если придется кормиться собственными сородичами.",
    "portuguese": "Tenha cuidado com aqueles que vêm do Fluxo de Almas. Pois eles farão qualquer coisa para sobreviver, mesmo que isso signifique se alimentar de seus semelhantes.",
    "chinese": "当心从灵魂之流里出来的敌人。他们为了活下去什么事都干得出来，包括同类相食。",
    "spanish": "Cuídate de lo que proviene de la Corriente de Almas. Sus criaturas harán lo que sea por sobrevivir, incluso alimentarse de los suyos.",
    "chinese_traditional": "當心那些來自靈魂之流的存在。為了生存，他們將不擇手段，甚至不惜吞噬同類。",
    "korean": "소울스트림에서 나온 존재들을 조심하십시오. 그들은 살아남기 위해 동족을 먹는 일도 마다하지 않습니다.",
    "japanese": "ソウルストリームの者には用心しなければならない。生き延びるためなら何でもする。例えそれが仲間を食らうことであっても。"
  },
