  "battleNameKey": {
    "key": "ScenarioData_battleNameKey-b14de4af3ec71025-ceebc74ae3004e44eb6b5dfecbc3a55f-v2",
    "english": "Corrupted Crusade",
    "french": "Croisade corrompue",
    "german": "Verdorbener Kreuzzug",
    "russian": "Крестовый поход оскверненных",
    "portuguese": "Cruzada Corrompida",
    "chinese": "腐化十字军",
    "spanish": "Cruzada corrupta",
    "chinese_traditional": "腐化十字軍",
    "korean": "타락한 성기사",
    "japanese": "堕落軍"
  },
  "battleDescriptionKey": {
    "key": "ScenarioData_battleDescriptionKey-c85e22820f8b7e77-ceebc74ae3004e44eb6b5dfecbc3a55f-v2",
    "english": "If Heaven's angels can become corrupted by the Titans, so can we. Strike them down before our forces become subject to the same corruption that befalls our enemies.",
    "french": "Si les anges du paradis peuvent être corrompus par les titans, nous aussi. Frappez-les avant que nos forces ne subissent la même corruption que celle qui frappe nos ennemis.",
    "german": "Wenn Titanen die Engel des Himmels verderben können, können sie das auch mit uns tun. Schlag sie zurück, ehe unsere Streitkräfte dasselbe Schicksal erleiden wie unsere Feinde.",
    "russian": "Если ангелы в Раю подвержены влиянию скверны, значит, и мы тоже. Уничтожьте их как можно скорее, пока эта зараза не перекинулась на наших воинов.",
    "portuguese": "Se os anjos do Céu podem ser corrompidos pelos Titãs, nós também podemos. Derrube-os antes que nossas forças fiquem sujeitas à mesma corrupção que se abate sobre nossos inimigos.",
    "chinese": "如果天堂的天使会遭到泰坦的腐化，那么我们也会。在我们的部队遭到像他们一样的腐化之前，击败他们。",
    "spanish": "Si los titanes pueden corromper a los ángeles, también pueden corrompernos a nosotros. Acaba con ellos antes de que nuestras fuerzas sufran la misma corrupción que aflige a nuestros enemigos.",
    "chinese_traditional": "如果天堂的天使能被泰坦腐化，那麼我們也可以。在我們的軍隊也遭受同樣腐化之前將敵人擊倒吧。",
    "korean": "티탄이 천상의 주민을 타락시킬 수 있다면, 우리도 타락할 수 있습니다. 타락의 전조가 닥치기 전에 빠르게 쓰러뜨리는 것이 좋습니다.",
    "japanese": "天界の天使たちが巨人族により堕落させられてしまうのなら、その危険はこちらにもある。自軍に敵軍と同じ堕落が降りかかる前に排除せよ。"
  },
