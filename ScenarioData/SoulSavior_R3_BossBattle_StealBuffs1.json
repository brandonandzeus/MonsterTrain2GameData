  "battleNameKey": {
    "key": "ScenarioData_battleNameKey-3e067d14a7dc5c97-e9063a87e33a0be45b3ee6a1958da3a5-v2",
    "english": "Tivi the Unruly",
    "french": "Tivi l'Indocile",
    "german": "Tivi der Ungezogene",
    "russian": "Тиви Непокорный",
    "portuguese": "Tivi, o Baderneiro",
    "chinese": "任性者蒂维",
    "spanish": "Tivi el Inquieto",
    "chinese_traditional": "不羈的蒂維",
    "korean": "무법자 티비",
    "japanese": "悪童のティヴィー"
  },
  "battleDescriptionKey": {
    "key": "ScenarioData_battleDescriptionKey-a5b201a713923a0d-e9063a87e33a0be45b3ee6a1958da3a5-v2",
    "english": "Tivi never fights fair. Tivi will slip through your defenses and bring your backline directly into the fray, leaving them vulnerable.",
    "french": "Tivi ne se bat jamais à la loyale. Il s'infiltrera derrière vos lignes pour traîner votre arrière-garde au cœur du combat, à la merci des coups.",
    "german": "Tivi kämpft niemals mit fairen Mitteln. Er wird durch deine Verteidigung schlüpfen und deine verwundbare Nachhut direkt ins Gemetzel einbinden.",
    "russian": "Тиви не знает честного боя. Он обойдет вашу оборону, а затем атакует и обезоружит ваших дальних бойцов.",
    "portuguese": "Tivi nunca luta de forma justa. Tivi escapará das suas defesas e levará a sua retaguarda diretamente para a batalha, deixando-a vulnerável.",
    "chinese": "蒂维从来都不讲武德。蒂维会渗透你的防线，并让你的后排单位直接参战，使其易受伤害。",
    "spanish": "Tivi nunca juega limpio. Evitará tus defensas para llevar a tu retaguardia al corazón de la lucha, dejándola vulnerable.",
    "chinese_traditional": "蒂維從不正大光明地戰鬥。他會溜過你的防線，將你的後排單位直接拉入戰局，使其暴露於危險之中。",
    "korean": "티비는 항상 비열한 방식으로 싸웁니다. 방어선을 뚫고 침투해 후열을 직접 전투에 끌어들이며, 그대로 노출되게 합니다.",
    "japanese": "ティヴィーは決して公平に戦わない。ティヴィーは防御をすり抜けて後方の者たちを戦いに巻き込み、危険に晒す。"
  },
