      "descriptions": {
        "key": "CollectableRelicData_descriptionKey-d95710a2fa35e84f-cfe0c4ace98e6dd40932ce8e45d2be5f-v2",
        "english": "<b>Selene</b> units get +[effect1.upgrade.bonusdamage][attack] during [fullmoon]. <b>Silent</b> units get +[effect0.upgrade.bonusdamage][attack] during [newmoon].",
        "french": "Les <b>Sélènes</b> gagnent +[effect1.upgrade.bonusdamage][attack] pendant la [fullmoon]. Les <b>Silencieux</b> gagnent +[effect0.upgrade.bonusdamage][attack] pendant la [newmoon].",
        "german": "<b>Selene</b>-Einheiten erhalten +[effect1.upgrade.bonusdamage][attack] bei [fullmoon]. <b>Stille</b>-Einheiten erhalten +[effect0.upgrade.bonusdamage][attack] bei [newmoon].",
        "russian": "<b>Селены</b> получают +[effect1.upgrade.bonusdamage][attack] в [fullmoon]. <b>Молчуны</b> получают +[effect0.upgrade.bonusdamage][attack] в [newmoon].",
        "portuguese": "As unidades de <b>Selenes</b> recebem +[effect1.upgrade.bonusdamage][attack] durante a [fullmoon]. As unidades de <b>Silenciosos</b> recebem +[effect0.upgrade.bonusdamage][attack] durante a [newmoon].",
        "chinese": "[fullmoon]期间，<b>月神女</b>单位获得 +[effect1.upgrade.bonusdamage][attack]。[newmoon]期间，<b>寂静者</b>单位获得 +[effect0.upgrade.bonusdamage][attack]。",
        "spanish": "Las unidades <b>selenitas</b> añaden +[effect1.upgrade.bonusdamage][attack] durante la [fullmoon]. Las unidades de <b>silenciosos</b> añaden +[effect0.upgrade.bonusdamage][attack] durante la [newmoon].",
        "chinese_traditional": "<b>塞勒涅</b>單位在[fullmoon]期間獲得+[effect1.upgrade.bonusdamage][attack]。<b>沉默</b>單位在[newmoon]期間獲得+[effect0.upgrade.bonusdamage][attack]。",
        "korean": "<b>세레네</b> 유닛은 [fullmoon] 동안 +[effect1.upgrade.bonusdamage][attack]을 획득합니다. <b>묵언자</b> 유닛은 [newmoon] 동안 +[effect0.upgrade.bonusdamage][attack]을 획득합니다.",
        "japanese": "[fullmoon]中に<b>セレーネ</b>ユニットが+[effect1.upgrade.bonusdamage][attack]を得る。[newmoon]中に<b>サイレント</b>ユニットが+[effect0.upgrade.bonusdamage][attack]を得る。"
      },
      "lore_tooltips": [
        {
          "key": "CollectableRelicData_data-4eaa63aa19bcda67-cfe0c4ace98e6dd40932ce8e45d2be5f-v2",
