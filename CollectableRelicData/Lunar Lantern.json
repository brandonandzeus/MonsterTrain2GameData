      "names": {
        "key": "CollectableRelicData_nameKey-9121040d51ee286e-cfe0c4ace98e6dd40932ce8e45d2be5f-v2",
        "english": "Lunar Lantern",
        "french": "Lanterne lunaire",
        "german": "Mondlaterne",
        "russian": "Лунный фонарь",
        "portuguese": "Lanterna Lunar",
