      "lore_tooltips": [
        {
          "key": "CharacterData_data-ea2a6e41cd72cf50-81017a85f1a2e4249bc7dd0c644a1571-v2",
          "english": "“I would be willing—no, happy—to lead these Caps to battle every day!”",
          "french": "<nobr>« Je</nobr> serais ravi de mener ces champis au combat tous les <nobr>jours ! »</nobr>",
          "german": "„Ich wäre bereit – nein, geehrt – diese Hüte jeden Tag in die Schlacht zu führen!“",
          "russian": "«Я готов... Нет, я просто счастлив ежедневно вести этих ребят в бой!»",
          "portuguese": "“Eu estaria disposto... Quero dizer, feliz por liderar esses cogumelos em batalha todos os dias!”",
          "chinese": "“我愿意——不，很乐意——每天率领这些蘑菇上阵杀敌！”",
          "spanish": "«Sería un honor... ¡no, un placer, liderar a estos hongos en batalla todos los días!».",
          "chinese_traditional": "「我願意——不，應該說我很榮幸每天帶領這些帽子去戰鬥！」",
          "korean": "\"나는 반드시... 아니, 기꺼이 이 버섯들을 데리고 매일 싸울 것입니다!\"",
          "japanese": "「毎日キノコたちを戦いで率いるのは構わない——いや、喜んで引き受けよう！」"
        }
      ],
