      "names": {
        "key": "CharacterData_nameKey-55929ce6e1984e96-0040ae3d30dea9a49ad7711f970614e3-v2",
        "english": "Reforming Ooze",
        "french": "Blob régénératif",
        "german": "Reformationsschleim",
        "russian": "Текучая жижа",
        "portuguese": "Gosma Imutável",
        "chinese": "重组软泥怪",
        "spanish": "Cieno reformador",
        "chinese_traditional": "重鑄軟泥",
        "korean": "되살아난 점액",
