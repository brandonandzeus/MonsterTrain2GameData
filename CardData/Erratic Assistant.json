      "names": {
        "key": "CharacterData_nameKey-3f57af0416d2537e-3afd6f2f5c7f59c4eba3cda9fc839237-v2",
        "english": "Erratic Assistant",
        "french": "Assistante erratique",
        "german": "Launische Assistentin",
        "russian": "Помощник-чудак",
        "portuguese": "Assistente Descontrolado",
        "chinese": "古怪助手",
        "spanish": "Ayudante errática",
        "chinese_traditional": "反常助手",
        "korean": "변덕스러운 조수",
        "japanese": "不器用助手"
      },
      "lore_tooltips": [
        {
          "key": "CharacterData_data-87dc54cc8855d56f-3afd6f2f5c7f59c4eba3cda9fc839237-v2",
          "english": "“I traded my hands with the doctor’s topiary trimming monstrosity. I think I got the better end of that deal.”",
          "french": "<nobr>« J'ai</nobr> échangé mes mains avec le monstre du docteur qui taille les topiaires. Je pense que j'ai fait une meilleure affaire que <nobr>lui. »</nobr>",
          "german": "„Ich tauschte meine Hände mit dem heckenschneidenden Monster des Doktors. Ich bin dabei ganz gut ausgestiegen, denke ich.“",
          "russian": "«Я обменялся руками с чудовищем доктора, подстригавшим топиарии. Думаю, в этой сделке я в выигрыше».",
          "portuguese": "“Troquei minhas mãos com o monstro jardineiro do médico. Acho que saí ganhando com esse negócio.”",
          "chinese": "“我用自己的手换来了博士的修剪用异肢。我觉得这波完全不亏。”",
          "spanish": "«Intercambié mis manos con la monstruosidad podadora del doctor. Creo que salí ganando».",
          "chinese_traditional": "「我用醫生的怪物剪刀換掉了我的手。我想這算是我佔了便宜。」",
          "korean": "\"박사님이 준비한 정원 손질용 기형체 손과 내 손을 맞바꿨다. 제법 남는 장사인 것 같다.\"",
          "japanese": "「私はドクターのトピアリーをトリミングする怪物と手を交換した。その取引で良い結果を得たと思う」"
        }
      ],
