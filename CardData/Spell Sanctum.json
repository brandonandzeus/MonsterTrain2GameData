  "cardLoreTooltipKeys": [
    {
      "key": "CardData_data-b9fefc4ffe1ddb13-9f5558ebb8a887640a6e706fabc912de-v2",
      "english": "“Carved these runes myself. A bit of magic here, and some engineerin’ there.”\n—Heph",
      "french": "<nobr>« J'ai</nobr> gravé ces runes moi-même. Un peu de magie par-ci, un peu d'ingénierie <nobr>par-là. »</nobr> \n— Heph",
      "german": "„Diese Runen habe ich selbst geschnitzt. Ein bisschen Magie hier, etwas Technik da ...“\n– Heph",
      "russian": "«Я сама вырезала эти руны. Чуть магии тут, чуть инженерии там...»\n— Геф",
      "portuguese": "“Eu mesma esculpi essas runas. Usei um pouco de magia e de engenharia.”\n— Heph",
      "chinese": "“这些符文是我亲手刻上去的。这里用了一点魔法，而这里用了一点工程学技术。”\n——赫芙",
      "spanish": "«Inscribí estas runas yo misma. Un poco de magia aquí, un poco de ingeniería allá...».\n—Heph",
      "chinese_traditional": "「這些符文是我自己刻的。有一點魔法，也有一些工程學。」\n——赫芙",
      "korean": "“이 룬은 내가 직접 새긴 거야. 여기는 약간의 마법이, 저기는 기술이 결합되어 있지.”\n- 헵",
      "japanese": "「このルーン文字は自分で刻んだのよ。魔法を少々、工学も少々ってね」\n—ヘフ"
    }
  ],
