      "lore_tooltips": [
        {
          "key": "CharacterData_data-47168bbe3a1459ae-86ceff6238ba66b4e89bda77853dbec0-v2",
          "english": "“Dr. Inga was the only one who would look at me like a human, not a creation.”",
          "french": "<nobr>« La</nobr> <nobr>Dr Inga</nobr> était la seule à me considérer comme un être humain et non comme une <nobr>création. »</nobr>",
          "german": "„Dr. Inga war die Einzige, die mich als Mensch und nicht als Kreatur betrachtete.“",
          "russian": "«Только доктор Инга смотрела на меня и видела человека, а не создание».",
          "portuguese": "“A Dra. Inga era a única que me tratava como um ser humano, não como uma criação.”",
          "chinese": "“英伽博士是唯一一个会把我当做人类，而不是创造物看待的人。”",
          "spanish": "«La Dra. Inga fue la única que me miraba como si fuera humano, no una creación».",
          "chinese_traditional": "「英格博士是唯一一個把我當人看，而不是當作創造物的人。」",
          "korean": "“잉가 박사님은 나를 창조물이 아닌 인간으로 바라봐 주신 유일한 분이셨습니다.”",
          "japanese": "「自分を作品ではなく人間のように見てくれるのは、インガ博士だけだった」"
        }
      ],
