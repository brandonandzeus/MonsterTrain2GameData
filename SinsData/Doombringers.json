      "descriptions": {
        "key": "SinsData_descriptionKey-4a367004807f17d8-5ae84e1f769cf884fafb4bdd29b8a641-v2",
        "english": "Stryx applies +[effect1.trigger0.effect0.power][attack] to Hallow on [slay]. Hallow applies +[effect0.trigger0.effect0.power][health] to Stryx on [incant].",
        "french": "Stryx applique +[effect1.trigger0.effect0.power][attack] à Hallow avec [slay]. Hallow applique +[effect0.trigger0.effect0.power][health] à Stryx avec [incant].",
        "german": "Stryx wendet beim [slay] +[effect1.trigger0.effect0.power][attack] auf Hallow an. Hallow wendet bei [incant] +[effect0.trigger0.effect0.power][health] auf Stryx an.",
        "russian": "[slay]: Стрикс дает Хэллоу +[effect1.trigger0.effect0.power][attack]. [incant]: Хэллоу дает Стрикс +[effect0.trigger0.effect0.power][health].",
        "portuguese": "Stryx concede +[effect1.trigger0.effect0.power][attack] ao Hallow durante o <b>Abate</b>. Hallow concede +[effect0.trigger0.effect0.power][health] à Stryx durante o [incant].",
        "chinese": "斯特里克斯触发[slay]时使哈洛获得 +[effect1.trigger0.effect0.power][attack]。哈洛触发[incant]时使斯特里克斯获得 +[effect0.trigger0.effect0.power][health]。",
        "spanish": "Estrix añade +[effect1.trigger0.effect0.power][attack] a Sacro en [slay]. Sacro añade +[effect0.trigger0.effect0.power][health] a Estrix al aplicar [incant].",
        "chinese_traditional": "史崔克斯在[slay]時對哈洛施加+[effect1.trigger0.effect0.power][attack]。哈洛在[incant]時對史崔克斯施加+[effect0.trigger0.effect0.power][health]。",
        "korean": "[slay] 시 스트릭스가 할로우에게 +[effect1.trigger0.effect0.power][attack]을 부여합니다. [incant] 시 할로우가 스트릭스에게 +[effect0.trigger0.effect0.power][health]을 부여합니다.",
        "japanese": "ストリクスは[slay]時にハロウに+[effect0.trigger0.effect0.power][health]を付与する。ハロウは[incant]時にストリクスに+[effect1.trigger0.effect0.power][attack]を付与する。"
