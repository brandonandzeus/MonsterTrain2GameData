      "descriptions": {
        "key": "SinsData_descriptionKey-1ffa1316ac41b567-0b82000b050a0a6408e1607c95a69431-v2",
        "english": "Stryx applies +[effect1.trigger0.effect0.power][attack] to Hallow on [revenge]. Hallow applies +[effect0.trigger0.effect0.power][health] to Stryx on [siphon].",
        "french": "Stryx applique +[effect1.trigger0.effect0.power][attack] à Hallow avec [revenge]. Hallow applique +[effect0.trigger0.effect0.power][health] à Stryx avec [siphon].",
        "german": "Stryx wendet beim [revenge] +[effect1.trigger0.effect0.power][attack] auf Hallow an. Hallow wendet bei [siphon] +[effect0.trigger0.effect0.power][health] auf Stryx an.",
        "russian": "[revenge]: Стрикс дает Хэллоу +[effect1.trigger0.effect0.power][attack]. [siphon]: Хэллоу дает Стрикс +[effect0.trigger0.effect0.power][health].",
        "portuguese": "Stryx concede +[effect1.trigger0.effect0.power][attack] ao Hallow durante o <b>Abate</b>. Hallow concede +[effect0.trigger0.effect0.power][health] à Stryx durante o [siphon].",
        "chinese": "斯特里克斯触发 [revenge] 时使哈洛获得 +[effect1.trigger0.effect0.power][attack]。哈洛触发 [siphon] 时使斯特里克斯获得 +[effect0.trigger0.effect0.power][health]。",
        "spanish": "Estrix añade +[effect1.trigger0.effect0.power][attack] a Sacro como [revenge]. Sacro añade +[effect0.trigger0.effect0.power][health] a Estrix al activar [siphon].",
        "chinese_traditional": "史崔克斯在[revenge]時對哈洛施加+[effect1.trigger0.effect0.power][attack]。哈洛在[siphon]時對史崔克斯施加+[effect0.trigger0.effect0.power][health]。",
        "korean": "[revenge] 시 스트릭스가 할로우에게 +[effect1.trigger0.effect0.power][attack]을 부여합니다. [siphon] 시 할로우가 스트릭스에게 +[effect0.trigger0.effect0.power][health]을 부여합니다.",
        "japanese": "ストリクスは[revenge]時にハロウに+[effect0.trigger0.effect0.power][health]を付与する。ハロウは[siphon]時にストリクスに+[effect1.trigger0.effect0.power][attack]を付与する。"
      },
