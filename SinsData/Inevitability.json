      "descriptions": {
        "key": "SinsData_descriptionKey-e3d2104705b0db76-f092adb7598318c4e9721a3ccc3706cf-v2",
        "english": "Stryx applies +[effect1.trigger0.effect0.power][attack] to Hallow on <b>Loop</b>. Hallow applies +[effect0.trigger0.effect0.power][health] to Stryx on [resolve].",
        "french": "Stryx applique +[effect1.trigger0.effect0.power][attack] à Hallow avec <b>Boucle</b>. Hallow applique +[effect0.trigger0.effect0.power][health] à Stryx avec [resolve].",
        "german": "Stryx wendet beim <b>Wiederholen</b> +[effect1.trigger0.effect0.power][attack] auf Hallow an. Hallow wendet beim [resolve] +[effect0.trigger0.effect0.power][health] auf Stryx an.",
        "russian": "<b>Круг</b>: Стрикс дает Хэллоу +[effect1.trigger0.effect0.power][attack]. [resolve]: Хэллоу дает Стрикс +[effect0.trigger0.effect0.power][health].",
        "portuguese": "Stryx concede +[effect1.trigger0.effect0.power][attack] ao Hallow durante o <b>Ciclo</b>. Hallow concede +[effect0.trigger0.effect0.power][health] à Stryx durante a [resolve].",
        "chinese": "斯特里克斯触发<b>循环</b>时使哈洛获得 +[effect1.trigger0.effect0.power][attack]。哈洛触发[resolve]时使斯特里克斯获得 +[effect0.trigger0.effect0.power][health]。",
        "spanish": "Estrix añade +[effect1.trigger0.effect0.power][attack] a Sacro en <b>Bucle</b>. Sacro añade +[effect0.trigger0.effect0.power][health] a Estrix al aplicar [resolve].",
        "chinese_traditional": "史崔克斯在<b>迴圈</b>時對哈洛施加+[effect1.trigger0.effect0.power][attack]。哈洛在[resolve]時對史崔克斯施加+[effect0.trigger0.effect0.power][health]。",
        "korean": "<b>순환</b> 시 스트릭스가 할로우에게 +[effect1.trigger0.effect0.power][attack]을 부여합니다. [resolve] 시 할로우가 스트릭스에게 +[effect0.trigger0.effect0.power][health]을 부여합니다.",
        "japanese": "ストリクスは<b>ループ</b>時にハロウに+[effect0.trigger0.effect0.power][health]を付与する。ハロウは[resolve]時にストリクスに+[effect1.trigger0.effect0.power][attack]を付与する。"
      },
