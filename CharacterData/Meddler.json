  "characterLoreTooltipKeys": [
    {
      "key": "CharacterData_data-8589d7b9c76afde6-5080385e80e90414a829ad60ff53eb2b-v2",
      "english": "“You can’t take the dust out of stardust just as you can’t take the meddle out of the meddler.”",
      "french": "<nobr>« À</nobr> fouineuse, fouineuse et <nobr>demi. »</nobr>",
      "german": "„Wo Sternenstaub ist, sind auch Sterne. Und wo der Pfuscher ist, wird eben gepfuscht.“",
      "russian": "«Нельзя вынуть из звездной пыли пыль, а из Проказника — проказы».",
      "portuguese": "“Não se pode tirar a poeira da Poeira Estelar, assim como não se pode tirar a abelha do abelhudo.”",
      "chinese": "“等鸡吃完米，狗舔完面，火烧断锁，搞事精就不会搞事情了。”",
      "spanish": "«No puedes quitarle el polvo al polvo estelar ni el entrometimiento al Metomentodo».",
      "chinese_traditional": "「你不能把塵埃從星塵中分離，就像你不能把愛管閒事的個性從愛管閒事的人體內抽離一樣。」",
      "korean": "\"매들러에게 참견을 빼놓을 수 없듯, 별가루에서 가루가 빠질 수는 없는 법이지.\"",
      "japanese": "「口を挟んでくる者から口だけを取り除くことができないのと同じように、スターダストから塵だけを取り除くことはできない」"
    }
  ],
