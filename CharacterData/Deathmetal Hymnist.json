        "russian": "Трель-металлист",
        "portuguese": "Hinógrafo Metaleiro",
        "chinese": "死亡金属竖琴手",
        "spanish": "Himnista de death metal",
        "chinese_traditional": "死亡金屬讚美詩歌手",
