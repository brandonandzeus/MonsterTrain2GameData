      "lore_tooltips": [
        {
          "key": "CharacterData_data-f20c16a7dbf90a33-edbbc1fd3aec1bb438e8aeb7b2160ed8-v2",
          "english": "“We’re all a flash in the abyss, a song in the void. Dust will be our legacy!”",
          "french": "<nobr>« Nous</nobr> ne sommes qu'un éclair dans l'abîme, une chanson dans le Néant. La poussière sera notre <nobr>héritage ! »</nobr>",
          "german": "„Wir sind alle ein Blitz im Abgrund, ein Lied in der Leere. Der Staub wird unser Vermächtnis sein!“",
          "russian": "«Все мы — вспышка в Бездне; песнь, звучащая в пустоте. После нас останется лишь прах!»",
          "portuguese": "“Somos todos uma luz no abismo, uma canção no vácuo. O pó será o nosso legado!”",
          "chinese": "“我们都是深渊中的闪光，虚空中的歌谣。尘埃将是我们的遗产！”",
          "spanish": "«No somos más que un destello en el abismo, una canción en el vacío. ¡El polvo será nuestro legado!».",
          "chinese_traditional": "「我們都是深淵中的閃光、虛空中的歌聲。塵埃將是我們的遺產！」",
          "korean": "\"우리는 심연 속의 번쩍임이요, 공허 속의 한 줄기 노래이니. 남는 건 오직 먼지뿐이리라!\"",
          "japanese": "「俺たちはみな深淵の中の閃光、虚無の中の歌。塵が俺たちの遺産となる！」"
        }
      ],
