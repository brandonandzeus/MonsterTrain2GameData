      "names": {
        "key": "CharacterData_nameKey-80199530a95c83c2-0d5dcf7fd6e2e254a94417b7bfb80d77-v2",
        "english": "Entropy",
        "french": "Entropie",
        "german": "Entropie",
        "russian": "Энтропия",
        "portuguese": "Entropia",
        "chinese": "混乱泰坦",
        "spanish": "Entropía",
        "chinese_traditional": "熵",
        "korean": "엔트로피",
        "japanese": "エントロピー"
      },
      "lore_tooltips": [
        {
          "key": "CharacterData_data-bfdea2138a5c37b9-0d5dcf7fd6e2e254a94417b7bfb80d77-v2",
          "english": "Everything moves towards the inevitable. Entropy is neither fury, nor command, but is instead an unyielding, unfeeling force of nature.",
          "french": "Tout se dirige vers l'inévitable. Entropie n'est ni fureur, ni ordre, mais une force de la nature inflexible et insensible.",
          "german": "Alles steuert auf das Unvermeidliche zu. Entropie kennt weder Wut noch Befehl, sondern nur unnachgiebige, gefühllose Gewalt.",
          "russian": "Все движется к неизбежному. Энтропия далек от слепой ярости и контроля. Ему близка непреклонная и безразличная сила природы.",
          "portuguese": "Tudo se move em direção ao inevitável. A Entropia não é nem fúria nem comando, mas sim uma força da natureza inflexível e insensível.",
          "chinese": "万事万物都朝着必然的方向发展。混乱泰坦既不是愤怒，也不是掌控，而是一种不屈又无情的自然力量。",
          "spanish": "Todo avanza hacia lo inevitable. Entropía no es furia ni control, sino una fuerza de la naturaleza imparable e indiferente.",
          "chinese_traditional": "一切都走向不可避免的結局。熵既不是憤怒，也不是命令，而是一種無情、無感的自然力量。",
          "korean": "모든 것은 피할 수 없는 운명을 향해 나아간다. 엔트로피는 분노도, 명령도 아닌, 감정도 없고 양보조차 않는 자연의 힘 그 자체이다.",
          "japanese": "すべては必然に向かって進む。エントロピーは激怒でも支配でもなく、むしろ不屈で冷酷な自然の力なのだ。"
        }
      ],
