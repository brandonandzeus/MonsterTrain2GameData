  "descriptionKey": {
    "key": "SoulData_descriptionKey-14cd1079f44b7259-0f2fd9f774709d647a301cbb2c88c0c4-v2",
    "english": "[slay]: +[effect0.upgrade.trigger0.effect0.power][capacity]. Friendly units gain +[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack] and +[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health].",
    "french": "<nobr>[slay] :</nobr> +[effect0.upgrade.trigger0.effect0.power][capacity]. Les alliés gagnent +[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack] et +[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health].",
    "german": "[slay]: +[effect0.upgrade.trigger0.effect0.power][capacity]. Verbündete Einheiten erhalten +[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack] und +[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health].",
    "russian": "[slay]: +[effect0.upgrade.trigger0.effect0.power][capacity]. Дает союзникам +[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack] и +[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health].",
    "portuguese": "[slay]: +[effect0.upgrade.trigger0.effect0.power][capacity]. As unidades aliadas recebem +[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack] e +[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health].",
    "chinese": "[slay]：+[effect0.upgrade.trigger0.effect0.power][capacity]。友方单位获得 +[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack] 和 +[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health]。",
    "spanish": "[slay]: +[effect0.upgrade.trigger0.effect0.power][capacity]. Las unidades aliadas añaden +[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack] y +[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health].",
    "chinese_traditional": "[slay]：+[effect0.upgrade.trigger0.effect0.power][capacity]。友方單位獲得+[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack]和+[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health]。",
    "korean": "[slay]: +[effect0.upgrade.trigger0.effect0.power][capacity]. 아군 유닛들이 +[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack] 및 +[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health]을 획득합니다.",
    "japanese": "[slay]：+[effect0.upgrade.trigger0.effect0.power][capacity]。味方ユニットが+[effect0.upgrade.trigger0.effect1.upgrade.bonusdamage][attack]と+[effect0.upgrade.trigger0.effect1.upgrade.bonushp][health]を得る。"
  },
